<Doctype html>
<html>
<head>
    <!-- Style sheet-->
     <style>
        *{
            margin: 0;
            padding: 0;
        }
        p{
            font-size: 20px;
            font-weight: bold;
            color: rgb(59, 12, 12);
            border-bottom: 1px solid rgb(59, 12, 12);
        }
        body{
            /*Box design*/
            background-color: rgb(111, 22, 22);
            width: 100%;
            height: 100vh;
            /*display properties*/
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        #container{
            /*Box design*/
            background-color: rgb(223, 153, 153);
            width: 400px;
            height: 450px;
            border: 3px solid rgb(246, 246, 246);
            border-radius: 35px;
            /*display properties*/
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            align-items: center;
        }

        #watch{
            /*Box design*/
           /* background-color: rgba(111, 22, 22, 0.675);*/
            width: calc(100% - 75px);
            height: 75px;
            border: 1px solid rgb(255, 255, 255);
            border-radius: 15px;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
            /*display properties*/
            display: flex;
            flex-direction: row;
            justify-content: space-evenly;
            align-items: center;

        }

        span{
            /*font*/
            font-size: 50px;
            font-weight: bold;
            color: rgb(247, 243, 243);
        }

        #buttonCont{
            /*box Design*/
            width: inherit;
            height: 50px;
            /*display properties*/
            display: flex;
            flex-direction: row;
            justify-content: space-around;
            align-items:end;
        }
        
        button{
            /*box design*/
            width: 115px;
            height: 50px;
            border: 1.5px solid rgb(255, 239, 239);
            border-radius: 10px;
            background-color: rgba(130, 10, 10, 0.577);
            /*font*/
            font-size: 25px;
            font-weight: bold;
            color: rgb(255, 255, 255);
        }
        #start:hover, #stop:hover, #reset:hover{
            /*box design*/
            background-color: rgba(130, 10, 10, 0.877);
            border: 1.5px solid rgb(255, 239, 239);
            border-radius: 10px;
            /*font*/
            font-size: 25px;
            font-weight: bold;
            color: rgb(255, 255, 255);
        }
        #start:hover{
            box-shadow: 0 0 10px green;
        }
        #stop:hover{
            box-shadow: 0 0 10px red;
        }
        #reset:hover{
            box-shadow: 0 0 10px blue;
        }

     </style>

     <!--Title-->
    <title>My watch</title>
</head>
<body>
    <!--Conatainer for the watch-->
    <div id="container">

        <p>Verona Mahilet - IT 2320 - Lab5</p>
        <!--Watch display-->
        <div id="watch">
            <span id="hour">00</span> 
            <span>:</span>
            <span id="minute">00</span> 
            <span>:</span>
            <span id="second">00</span>
            <span>.</span>
            <span id="tenths">0</span>
        </div>

        <!--Container for the buttons-->
        <div id="buttonCont">
            <button id="start">Start</button>
            <button id="stop">Stop</button>
            <button id="reset">Reset</button>
        </div>
    </div>

    <!--Script-->
    <script> 
        // variables 
        let hour = 0;
        let minute = 0;
        let second = 0;
        let tenths = 0;
        let timer;
        
        // Update & Display time function, format 00:00:00
        function updateDisplay(){
            document.getElementById("hour").textContent = String(hour).padStart(2,"0");
            document.getElementById("minute").textContent = String(minute).padStart(2,"0");
            document.getElementById("second").textContent = String(second).padStart(2,"0");
            document.getElementById("tenths").textContent = tenths;
        }

        //  Start Timer Functions
        function startTimer(){
            if (timer) return; // I noticed that each time i click start it create a new timer making the watch run faster.
            function incrementTime(){
                tenths++;
                if(tenths === 10){
                    tenths = 0;
                    second++;
                }
                if(second === 60){
                    second = 0;
                    minute++;
                }
                if(minute === 60){
                    minute = 0;
                    hour++;
                }
                updateDisplay();
            }
            timer = setInterval(incrementTime, 100);
        }

        // Stop Timer Function
        function stopTimer(){
            clearInterval(timer);
            timer = null; // Reset timer variable to allow starting again
        }

        // Reset Timer Function
        function resetTimer(){
            stopTimer();
            hour = 0;
            minute = 0;
            second = 0;
            tenths = 0;
            updateDisplay();
        }

        // Event Listeners for buttons
        document.getElementById("start").addEventListener("click", startTimer);
        document.getElementById("stop").addEventListener("click", stopTimer);
        document.getElementById("reset").addEventListener("click", resetTimer);
    </script>
</body>
</html>

